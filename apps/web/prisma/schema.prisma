generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

enum LikeValue {
  LIKE
  DISLIKE
}

model User {
  id              String                  @id @default(cuid())
  name            String?
  email           String?                 @unique
  emailVerified   DateTime?
  image           String?
  accounts        Account[]
  sessions        Session[]
  roles           UserRole[]
  likes           UserLike[]
  criteria        UserCriteria[]
  recommendations RecommendationHistory[]
  analysis        AnalysisMessage[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model Account {
  userId                String
  type                  String
  provider              String
  providerAccountId     String
  refresh_token         String?   @db.Text
  access_token          String?   @db.Text
  expires_at            Int?
  token_type            String?
  scope                 String?
  id_token              String?   @db.Text
  session_state         String?
  refresh_token_expires Int?
  oauth_token_secret    String?
  oauth_token           String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId        String
  permissionId  String
  assignedAt    DateTime   @default(now())
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Company {
  id                   Int                    @id @default(autoincrement())
  slug                 String                 @unique
  name                 String
  ticker               String?
  sector               String
  country              String?
  website              String?
  description          String?                @db.Text
  financialMetrics     FinancialMetrics[]
  extraFinancial       ExtraFinancialMetrics?
  likes                UserLike[]
  recommendations      RecommendationHistory[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

model FinancialMetrics {
  id            Int       @id @default(autoincrement())
  companyId     Int
  asOf          DateTime
  revenue       Decimal?  @db.Decimal(18, 4)
  netIncome     Decimal?  @db.Decimal(18, 4)
  debt          Decimal?  @db.Decimal(18, 4)
  shareholdersEquity Decimal? @db.Decimal(18, 4)
  freeCashFlow  Decimal?  @db.Decimal(18, 4)
  ebitda        Decimal?  @db.Decimal(18, 4)
  peRatio       Decimal?  @db.Decimal(10, 4)
  netMargin     Decimal?  @db.Decimal(10, 4)
  metadata      Json?
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([companyId, asOf])
  @@index([asOf])
}

model ExtraFinancialMetrics {
  id              Int       @id @default(autoincrement())
  companyId       Int       @unique
  environmental   Json?
  social          Json?
  governance      Json?
  metadata        Json?
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model UserLike {
  id         String    @id @default(cuid())
  userId     String
  companyId  Int
  value      LikeValue
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
}

model UserCriteria {
  id         String    @id @default(cuid())
  userId     String
  criteria   Json
  metadata   Json?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, createdAt])
}

model RecommendationHistory {
  id          String    @id @default(cuid())
  userId      String
  companyId   Int?
  companyName String?
  score       Decimal?  @db.Decimal(10, 4)
  context     Json?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([companyId])
}

model AnalysisMessage {
  id           String    @id @default(cuid())
  userId       String
  promptText   String    @db.Text
  responseText String    @db.Text
  keywords     String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
}
